{
  "name": "spy-houdai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "tsc --noEmit && vite build",
    "build:lan": "rm -rf dist && tsc --noEmit && BASE_PATH=/ vite build",
    "build:pages": "rm -rf dist && tsc --noEmit && BASE_PATH=/spy-houdai/ vite build && cp dist/index.html dist/404.html",
    "serve:lan": "npm run build:lan && node scripts/serve_lan.mjs",
    "sim": "tsx scripts/simulate.ts",
    "sim:party": "tsx scripts/simulate_party.ts",
    "playtest:ai": "tsx scripts/ai_alpha_preflight.ts",
    "playtest:m5": "tsx scripts/m5_public_alpha_preflight.ts",
    "release:m6": "tsx scripts/m6_release_preflight.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "lucide-react": "^0.562.0",
    "peerjs": "^1.5.5",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  }
}
